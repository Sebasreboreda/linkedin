# =============================================================================
# LinkedIn — credenciales de acceso (login.py)
# =============================================================================
# Cuenta con la que el scraper inicia sesión en LinkedIn.
# Solo se usa si ejecutas login.py o si SCRAPING_RUN_LOGIN=1.

LINKEDIN_EMAIL=juanperezmercanza@gmail.com

# Contraseña de esa cuenta de LinkedIn.

LINKEDIN_PASSWORD=GrupoLinkedin

# =============================================================================
# PostgreSQL — base de datos (scrapping_general.py)
# =============================================================================
# Servidor donde corre PostgreSQL. localhost = Docker o instalación local.

PGHOST=localhost

# Puerto de PostgreSQL. El estándar es 5432.

PGPORT=5432

# Nombre de la base de datos donde están perfiles, métricas y publicaciones.

PGDATABASE=Linkedin_Scrapper

# Usuario de PostgreSQL con permiso de lectura/escritura en esa BD.

PGUSER=postgres

# Contraseña de ese usuario. Déjala vacía solo si tu Postgres no tiene contraseña.

PGPASSWORD=

# =============================================================================
# Scraping — qué perfiles revisar (scrapping_general.py)
# =============================================================================
# Un solo perfil por nombre (como aparece en LinkedIn). Opcional.
# Solo se usa si SCRAPING_ACCOUNTS está vacío o comentado.

# SCRAPING_ACCOUNT=Brais Moure

# Lista de perfiles separados por ; (sin comillas).
# Se usa si la BD está vacía, o para añadir cuentas nuevas que aún no existan en perfiles.
# Los que ya están en BD se leen de la base de datos y se fusionan con esta lista.

SCRAPING_ACCOUNTS=Brais Moure;Pedro Buerbaum;Andrés Millán;Jose Elías Navarro;Isabel Díaz Ayuso;Rafael Nadal;

# =============================================================================
# Scraping — ventana de tiempo (scrapping_general.py + setup_scheduler_task.py)
# =============================================================================
# Perfiles que YA tienen datos en BD: cuántos días de posts mirar hacia atrás.
# También define cada cuántos días se repite la tarea en el Programador de tareas.

SCRAPING_DAYS=1

# Perfiles NUEVOS (sin publicaciones en BD): meses iniciales a recorrer.
# Al ver un post de hace N meses (ej. "1 mes"), deja de hacer scroll.

SCRAPING_MONTHS_INITIAL=1

# =============================================================================
# Tarea programada Windows — setup_scheduler_task.py
# =============================================================================
# Hora diaria de ejecución automática, formato 24 h (HH:MM).

SCRAPING_SCHEDULE_TIME=11:30

# Zona horaria de referencia (solo documentación; Windows usa la hora local del PC).

SCRAPING_TIMEZONE=Europe/Madrid

# =============================================================================
# Scheduler — scheduler.py (ejecución automática del job)
# =============================================================================
# 1 = ejecutar login.py automáticamente antes de cada scraping (un intento).
# 0 = no reloguear; solo usar state.json existente.

SCRAPING_RUN_LOGIN=1

# =============================================================================
# Notificaciones de error por correo — scheduler.py / login.py
# =============================================================================
# 1 = enviar correo SMTP si hay error.
# 0 = solo mensajes en consola / log.

SCRAPING_NOTIFY_ON_ERROR=1

# Servidor SMTP del proveedor de correo (Gmail: smtp.gmail.com).

SMTP_HOST=smtp.gmail.com

# Puerto SMTP con TLS (Gmail: 587).

SMTP_PORT=587

# Email desde el que se envía el aviso (debe coincidir con la cuenta SMTP).

SMTP_USER=juanperezmercanza@gmail.com

# Contraseña de aplicación de Google (no la contraseña normal de Gmail).
# Crear en: Cuenta Google → Seguridad → Contraseñas de aplicaciones.

SMTP_PASSWORD=wifgephsfesyuewg

# Email que recibe el aviso de error (puede ser el mismo que SMTP_USER).

NOTIFY_EMAIL_TO=juanperezmercanza@gmail.com
