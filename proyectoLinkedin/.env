# LinkedIn — credenciales de acceso (login.py)
# Email de la cuenta con la que inicias sesión en LinkedIn
LINKEDIN_EMAIL=juanperezmercanza@gmail.com

# Contraseña de esa cuenta
LINKEDIN_PASSWORD=GrupoLinkedin

# PostgreSQL — base de datos donde se guardan perfiles y publicaciones
# Dirección del servidor (localhost si usas Docker en tu PC)
PGHOST=localhost

# Puerto de PostgreSQL 
PGPORT=5432

# Nombre de la base de datos
PGDATABASE=Linkedin_Scrapper

# Usuario de PostgreSQL
PGUSER=postgres

# Contraseña de PostgreSQL
PGPASSWORD=

# =============================================================================
# Scraping — qué perfiles revisar
# =============================================================================
# Un solo perfil (opcional). Se usa si SCRAPING_ACCOUNTS está vacío
# SCRAPING_ACCOUNT=Brais Moure
# Lista de perfiles separados por ; Se usan si la BD no tiene perfiles,
# o para añadir cuentas nuevas que aún no estén en la base de datos
SCRAPING_ACCOUNTS=Brais Moure;Pedro Buerbaum;Andrés Millán;Jose Elías Navarro;Isabel Díaz Ayuso;Rafael Nadal;Miguel Ángel (midudev) Durán García;

# ============================================================================
# Scraping — ventana de tiempo
# ============================================================================
# Perfiles YA registrados en la BD: último día de posts + seguidores actuales
# También define cada cuántos días se ejecuta la tarea programada
SCRAPING_DAYS=1

# Solo perfiles NUEVOS (aún no están en la BD): carga inicial del último mes
# Al aparecer "1 mes" en un post, se deja de hacer scroll
SCRAPING_MONTHS_INITIAL=1

# =============================================================================
# Tarea programada (Windows) — setup_scheduler_task.py
# =============================================================================
# Hora diaria de ejecución en formato HH:MM (24 h)
SCRAPING_SCHEDULE_TIME=11:30

# Zona horaria de referencia (informativa; la tarea usa la hora local del sistema)

SCRAPING_TIMEZONE=Europe/Madrid
# =============================================================================
# Scheduler — scheduler.py
# ============================================================================
# 1 = ejecutar login.py antes de cada scraping (puede pedir verificación manual)
# 0 = no reloguear; usar state.json existente (recomendado en tarea automática)
SCRAPING_RUN_LOGIN=0